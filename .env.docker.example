# Template pour lancer la stack avec docker-compose (docker-compose.yml).
# Copier vers .env et renseigner les valeurs — aucune URL / identifiant en dur dans le compose.
#
# ⚠️  OBLIGATOIRE : AUTH_SECRET doit faire au moins 32 caractères, sinon l'app quitte en erreur.
#     Générer une valeur : openssl rand -base64 32


# Postgres (service postgres du compose)
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=taskmaster
POSTGRES_PORT=5432

# Redis (service redis du compose)
REDIS_PORT=6379

# Backend Configuration
PORT=3000
NODE_ENV=production
BACKEND_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# Database — construit automatiquement par docker-compose à partir de POSTGRES_* (pas besoin de DATABASE_URL ici)
# Redis — idem, injecté par le compose (redis://redis:6379)

# Security — OBLIGATOIRE : remplacer par une clé d'au moins 32 caractères (openssl rand -base64 32)
AUTH_SECRET=your-32-characters-minimum-secret-key-change-it
AUTH_GRACE_WINDOW_ENABLED=true
AUTH_GRACE_WINDOW_SECONDS=10

# CORS (ex. http://localhost:3000 si tout sur le même port)
CORS_ORIGIN=http://localhost:3000

# Observability & Limits
LOG_LEVEL=info
PROCEDURE_MAX_SIZE_MB=5

# Storage & Backups (production) - OBLIGATOIRE : remplacer par une clé d'au moins 32 caractères (openssl rand -base64 32)
BACKUP_STORAGE_PATH=./backups
BACKUP_ENCRYPTION_KEY=your-secure-encryption-key-min-32-chars

# Web Push (optionnel)
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_CONTACT=mailto:admin@example.com

# Optional: override official GitHub repository for version checks
# VERSION_CHECK_REPO=your-org/taskmaster

# Image Docker à utiliser
TASKMASTER_IMAGE=mikaxy/taskmaster:latest
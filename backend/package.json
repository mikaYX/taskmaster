    "@simplewebauthn/server": "^13.2.3",
    "@types/opossum": "^8.1.9",
    "@types/rrule": "^2.1.7",
    "@willsoto/nestjs-prometheus": "^6.0.2",
    "archiver": "^7.0.1",
    "axios": "^1.13.5",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.69.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "cookie-parser": "^1.4.7",
    "cron": "4.3.5",
    "cron-parser": "^5.5.0",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "date-holidays": "^3.26.8",
    "dotenv": "^17.2.3",
    "form-data": "^4.0.5",
    "helmet": "^8.1.0",
    "ioredis": "^5.9.3",
    "ldapts": "^8.1.6",
    "mailgun.js": "^12.7.0",
    "nestjs-cls": "^6.2.0",
    "nestjs-pino": "^4.6.0",
    "node-mailjet": "^6.0.11",
    "nodemailer": "^7.0.13",
    "openid-client": "^5.7.1",
    "opossum": "^9.0.0",
    "otplib": "^13.3.0",
    "passport": "^0.7.0",
    "passport-headerapikey": "^1.2.2",
    "passport-jwt": "^4.0.1",
    "pg": "^8.18.0",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "prom-client": "^15.1.3",
    "puppeteer": "^24.37.5",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.2",
    "rrule": "^2.8.1",
    "rxjs": "^7.8.1",
    "semver": "^6.3.1",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"

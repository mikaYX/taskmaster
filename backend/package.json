{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "npx nest build",
    "format": "npx prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "npx nest start",
    "start:dev": "npx nest start --watch",
    "start:debug": "npx nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "npx eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "npx jest",
    "test:watch": "npx jest --watch",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "npx jest --config ./test/jest-e2e.json --forceExit",
    "test:auth:ci": "npx jest --config ./test/jest-e2e.json test/auth-flow.e2e-spec.ts --forceExit --coverage --collectCoverageFrom='src/auth/**/*.ts' --coverageDirectory='coverage-auth'",
    "test:auth:flaky": "node scripts/detect-flaky-auth.js",
    "typecheck": "npx tsc --noEmit -p tsconfig.build.json",
    "db:push": "npx prisma db push",
    "db:generate": "node scripts/prisma-generate.js",
    "db:seed-test-tasks": "ts-node --project tsconfig.json -r tsconfig-paths/register prisma/seed-test-tasks.ts",
    "db:seed-demo": "ts-node --project tsconfig.json -r tsconfig-paths/register prisma/seed-demo-for-docs.ts",
    "postinstall": "node scripts/prisma-generate.js"
  },
  "dependencies": {
    "@azure/msal-node": "^3.8.8",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/microservices": "^11.1.13",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/schedule": "^6.1.0",
    "@nestjs/serve-static": "^5.0.4",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/terminus": "^11.0.0",
    "@nestjs/throttler": "^6.5.0",
    "@node-saml/node-saml": "^5.1.0",
    "@node-saml/passport-saml": "^5.1.0",
    "@opentelemetry/auto-instrumentations-node": "0.50.2",
    "@opentelemetry/exporter-trace-otlp-http": "0.53.0",
    "@opentelemetry/resources": "1.30.1",
    "@opentelemetry/sdk-node": "0.53.0",
    "@opentelemetry/semantic-conventions": "1.28.0",

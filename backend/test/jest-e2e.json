{
  "moduleFileExtensions": [
    "js",
    "json",
    "ts"
  ],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^otplib$": "<rootDir>/../src/__mocks__/otplib.ts"
  },
  "setupFiles": [
    "<rootDir>/setup-env.ts"
  ]
}
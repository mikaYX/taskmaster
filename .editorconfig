# EditorConfig — https://editorconfig.org
# Assure une cohérence de style entre tous les éditeurs et contributeurs.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# TypeScript / JavaScript / JSON / CSS
[*.{ts,tsx,js,jsx,mjs,cjs,json,jsonc,css}]
indent_style = space
indent_size = 2

# Markdown — ne pas supprimer les espaces en fin de ligne
# (deux espaces = saut de ligne intentionnel)
[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

# YAML (GitHub Actions, Docker Compose…)
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# Prisma schema
[*.prisma]
indent_style = space
indent_size = 2

# Scripts Shell
[*.sh]
indent_style = space
indent_size = 2
end_of_line = lf

# Makefile — obligatoirement des tabulations
[Makefile]
indent_style = tab

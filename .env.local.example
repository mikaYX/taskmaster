# Backend Configuration
PORT=3000
NODE_ENV=development
BACKEND_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# Database
# Valeurs par défaut Docker Compose (docker-compose.yml)
DATABASE_URL=postgresql://taskmaster:taskmaster_dev@localhost:5432/taskmaster

# Redis
# Default for local: redis://localhost:6379
# Default for Docker: redis://redis:6379
REDIS_URL=redis://localhost:6379

# Security
# AUTH_SECRET doit faire au minimum 32 caractères — générer avec : openssl rand -base64 32
AUTH_SECRET=your-32-characters-minimum-secret-key-change-it
# Fenêtre de grâce pour la rotation des tokens (compensation de dérive horloge)
# Défaut code : 10s — Min : 1s — Max : 60s
AUTH_GRACE_WINDOW_ENABLED=true
AUTH_GRACE_WINDOW_SECONDS=10

# Premier démarrage
# Aucun compte admin par défaut — utiliser le Setup Wizard à l'adresse :
#   http://localhost:5173/setup
# Le wizard permet de créer le premier compte SUPER_ADMIN.

# Storage & Backups
# Required in Production
BACKUP_STORAGE_PATH=./backups
BACKUP_ENCRYPTION_KEY=your-secure-encryption-key-min-32-chars

# CORS (Required in Production)
CORS_ORIGIN=http://localhost:5173

# Observability
LOG_LEVEL=info
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Application Limits
PROCEDURE_MAX_SIZE_MB=5

# Web Push (VAPID) — Notifications Push navigateur
# Générer les clés avec : npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=BExamplePublicKeyBase64UrlEncoded...
# VAPID_PRIVATE_KEY=ExamplePrivateKeyBase64UrlEncoded...
# VAPID_CONTACT=mailto:admin@example.com

# (Optional) Override official GitHub repository for version checks
# VERSION_CHECK_REPO=your-org/taskmaster